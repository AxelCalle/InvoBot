# ─── WhatsApp Business API (Meta) ─────────────────────────────────────────────
WHATSAPP_TOKEN=EAAxxxxxxxxxx          # Token de acceso permanente de Meta
WHATSAPP_PHONE_ID=1234567890          # Phone Number ID de tu cuenta Business
WHATSAPP_VERIFY_TOKEN=mi_token_secreto # Token de verificación del webhook (tú lo inventas)
WHATSAPP_API_VERSION=v19.0

# ─── Anthropic Claude API ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-20250514

# ─── SISCON API ────────────────────────────────────────────────────────────────
SISCON_BASE_URL=https://api.tuempresa.com/siscon/v1
SISCON_API_KEY=siscon_key_xxxxxxxxxx
SISCON_EMPRESA_ID=001                 # ID de empresa en SISCON

# ─── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
LOG_LEVEL=info
